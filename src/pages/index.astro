---
// src/pages/index.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import { products } from '../data/products.js';

const visualProducts = products.filter(p => p.layer === 'visual').slice(0, 3);
const tacticalProducts = products.filter(p => p.layer === 'tactical').slice(0, 2);
---
<BaseLayout title="HANYA | Wabi-Sabi x Modern Pop Art Home Decor">
  <!-- Hero Section -->
  <section class="relative min-h-screen flex items-center justify-center pt-24 pb-12 overflow-hidden">
    <div class="container mx-auto px-6 md:px-12 grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
      <div class="lg:col-span-7 z-10">
        <div class="mb-6 flex items-center space-x-4">
          <span class="h-[1px] w-12 bg-black"></span>
          <span class="text-[10px] uppercase tracking-[0.4em] font-bold pop-accent">Sensory Layered Living</span>
        </div>
        <h1 class="text-7xl md:text-[10rem] font-light leading-[0.85] mb-10 tracking-tighter">
          Raw <span class="italic serif">Nature.</span><br>
          <span class="pop-accent">Neon</span> Soul.
        </h1>
        <div class="flex flex-col md:flex-row md:items-end space-y-8 md:space-y-0 md:space-x-12">
          <p class="text-lg font-light max-w-sm text-gray-500 leading-relaxed">
            Where the silent imperfection of <span class="text-black font-medium">Wabi-Sabi</span> collides with the electric pulse of <span class="text-black font-medium">Modern Pop Art</span>.
          </p>
          <a href="/visual" class="group relative inline-block px-12 py-5 bg-black text-white text-[10px] uppercase tracking-[0.3em] overflow-hidden">
            <span class="relative z-10">Explore the Layers</span>
            <div class="absolute inset-0 bg-pop translate-y-full group-hover:translate-y-0 transition-transform duration-500"></div>
          </a>
        </div>
      </div>
      
      <div class="lg:col-span-5 relative">
        <div class="aspect-[4/5] bg-gray-100 overflow-hidden wabi-border relative">
          <img src="https://images.unsplash.com/photo-1594913785162-e6786b42dea3?auto=format&fit=crop&q=80&w=1000" alt="Minimalist Zen Space" class="w-full h-full object-cover" style="filter:grayscale(0.3)">
          <div class="absolute top-8 right-8 vertical-text text-[10px] tracking-[0.5em] uppercase text-gray-400">
            Imperfection is Perfection
          </div>
        </div>
        <div class="absolute -bottom-12 -left-12 w-72 h-72 bg-pop neon-glow float-anim hidden lg:block overflow-hidden">
          <img src="https://images.unsplash.com/photo-1563089145-599997674d42?auto=format&fit=crop&q=80&w=600" alt="Neon Abstract" class="w-full h-full object-cover" style="mix-blend-mode:overlay;opacity:0.9">
          <div class="absolute inset-0" style="border:20px solid rgba(255,255,255,0.2)"></div>
          <div class="absolute inset-0 flex items-center justify-center">
            <span class="text-white text-3xl font-bold serif italic" style="transform:rotate(-12deg)">Contrast</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="px-6 md:px-12"><div class="h-[1px] w-full bg-gray-200"></div></div>

  <!-- Layer A: The Visual -->
  <section id="visual" class="py-32">
    <div class="container mx-auto px-6 md:px-12">
      <div class="flex flex-col md:flex-row justify-between items-start mb-24">
        <div class="max-w-2xl">
          <span class="text-[10px] uppercase tracking-[0.4em] mb-6 block text-gray-400">Layer 01 — The Visual</span>
          <h2 class="text-6xl md:text-8xl font-light italic serif leading-tight">Art & <span class="pop-accent">Statues</span></h2>
        </div>
        <div class="mt-8 md:mt-0 text-right">
          <p class="text-gray-400 max-w-xs text-[10px] uppercase tracking-[0.2em] leading-loose">
            Elongated silhouettes in blackened suar wood met by high-gloss "melting" resin. A dialogue between the organic and the synthetic.
          </p>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-16">
        {visualProducts.map((p) => (
          <div class="product-reveal group cursor-pointer">
            <a href={`/products/${p.slug}`}>
              <div class="aspect-[3/4] overflow-hidden bg-gray-50 wabi-border mb-8 relative hover-zoom">
                <img src={p.image} alt={p.name} class="product-img w-full h-full object-cover" />
                {p.badge && <div class={`absolute top-4 left-4 px-3 py-1 text-[8px] uppercase tracking-widest font-bold ${p.badgeStyle === 'pop' ? 'bg-pop text-white' : p.badgeStyle === 'dark' ? 'bg-black text-white' : 'bg-white text-black'}`}>{p.badge}</div>}
                {p.badgeStyle === 'pop' && <div class="absolute inset-0 bg-pop opacity-0 group-hover:opacity-40 transition-opacity" style="mix-blend-mode:color"></div>}
              </div>
              <div class="flex justify-between items-end">
                <div>
                  <h3 class="text-2xl mb-1 font-light">{p.name}</h3>
                  <p class="text-[10px] uppercase tracking-widest text-gray-400">{p.category}</p>
                </div>
                <span class="text-lg font-light">${p.price.toLocaleString()}</span>
              </div>
            </a>
          </div>
        ))}
      </div>

      <div class="mt-16 text-center">
        <a href="/visual" class="text-[10px] uppercase tracking-[0.3em] font-medium border-b border-black pb-1 hover:pop-accent transition-colors">View All Visual →</a>
      </div>
    </div>
  </section>

  <!-- Layer B: The Tactical -->
  <section id="tactical" class="py-32 bg-[#121212] text-[#fdfdfb]">
    <div class="container mx-auto px-6 md:px-12">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-20 items-center">
        <div class="lg:col-span-5 order-2 lg:order-1">
          <span class="text-[10px] uppercase tracking-[0.4em] mb-6 block text-gray-600">Layer 02 — The Tactical</span>
          <h2 class="text-6xl md:text-8xl font-light italic serif leading-tight mb-12">Fusion <br><span class="pop-accent">Tactics.</span></h2>
          
          <div class="space-y-20">
            {tacticalProducts.map((p) => (
              <div class="group cursor-pointer">
                <a href={`/products/${p.slug}`}>
                  <div class="flex justify-between items-center mb-4">
                    <h3 class="text-3xl font-light">{p.name}</h3>
                    <span class="text-sm font-light text-gray-500">${p.price.toLocaleString()}</span>
                  </div>
                  <p class="text-sm text-gray-500 font-light leading-relaxed mb-6">{p.description.substring(0, 90)}…</p>
                  <div class="h-[1px] w-full bg-zinc-800 relative overflow-hidden">
                    <div class="absolute inset-0 bg-pop -translate-x-full group-hover:translate-x-0 transition-transform duration-700"></div>
                  </div>
                </a>
              </div>
            ))}
          </div>

          <div class="mt-16">
            <a href="/tactical" class="text-[10px] uppercase tracking-[0.3em] font-medium border-b border-white pb-1 text-white hover:text-pop-neon transition-colors">View All Tactical →</a>
          </div>
        </div>

        <div class="lg:col-span-7 order-1 lg:order-2">
          <div class="relative">
            <div class="aspect-[4/3] bg-zinc-900 overflow-hidden">
              <img src="https://images.unsplash.com/photo-1586023492125-27b2c045efd7?auto=format&fit=crop&q=80&w=1200" alt="Mid Century Modern Icons" class="w-full h-full object-cover opacity-60 hover:opacity-100 transition-opacity duration-1000" />
            </div>
            <div class="absolute -top-10 -right-10 bg-pop p-16 hidden xl:block neon-glow">
              <h4 class="text-4xl serif italic text-white mb-4">The Bones</h4>
              <p class="text-[10px] text-white/80 uppercase tracking-[0.3em] leading-loose">Refurbished Mid-Century Icons.<br>Eames & Jeanneret.</p>
            </div>
            <div class="absolute -bottom-6 left-12 bg-white text-black p-6 wabi-border">
              <p class="text-[10px] uppercase tracking-[0.3em] font-bold">Japandi-Bali Fusion</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Layer C: The Auditory -->
  <section id="auditory" class="py-32 relative">
    <div class="container mx-auto px-6 md:px-12">
      <div class="flex flex-col items-center text-center mb-24">
        <span class="text-[10px] uppercase tracking-[0.4em] mb-6 block text-gray-400">Layer 03 — The Auditory</span>
        <h2 class="text-6xl md:text-9xl font-light italic serif leading-none mb-8">Vinyl & <span class="pop-accent">Vibration</span></h2>
        <p class="text-lg font-light text-gray-500 max-w-xl leading-relaxed">A dedicated corner for high-fidelity sound. Japanese City Pop meets Indie-Tropical rhythms.</p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
        <div class="lg:col-span-4 space-y-12">
          <a href="/products/minimalist-turntable" class="block p-10 border wabi-border hover:border-pop transition-colors duration-500 group" style="--pop-border: var(--pop-neon)">
            <h4 class="text-xs uppercase tracking-[0.3em] font-bold mb-6 pop-accent">The Hardware</h4>
            <h3 class="text-3xl font-light mb-4">Transparent Turntable</h3>
            <p class="text-sm text-gray-400 font-light mb-8">Minimalist design that disappears into your interior, leaving only the music.</p>
            <span class="text-xl font-medium">$1,850</span>
          </a>
          <a href="/products/plastic-love-vinyl" class="block p-10 border wabi-border hover:border-pop transition-colors duration-500 group">
            <h4 class="text-xs uppercase tracking-[0.3em] font-bold mb-6 text-black">The Curation</h4>
            <h3 class="text-3xl font-light mb-4">City Pop Essentials</h3>
            <p class="text-sm text-gray-400 font-light mb-8">Limited 180g pressings of Japanese 80s masterpieces.</p>
            <span class="text-xl font-medium">$65</span>
          </a>
        </div>

        <div class="lg:col-span-8">
          <div class="relative aspect-video overflow-hidden wabi-border bg-gray-100">
            <img src="https://images.unsplash.com/photo-1603048588665-791ca8aea617?auto=format&fit=crop&q=80&w=1200" alt="Vinyl Listening Station" class="w-full h-full object-cover" style="filter:grayscale(1)" />
            <div class="absolute inset-0" style="background:linear-gradient(to top,rgba(0,0,0,0.6),transparent)"></div>
            <div class="absolute bottom-12 left-12">
              <div class="flex items-center space-x-4">
                <div class="w-12 h-12 bg-pop rounded-full flex items-center justify-center" style="animation:pulse 2s infinite">
                  <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                </div>
                <div class="text-white">
                  <p class="text-[10px] uppercase tracking-[0.3em] font-bold">Now Playing</p>
                  <p class="text-lg serif italic">Plastic Love — Mariya Takeuchi</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="mt-16 text-center">
        <a href="/auditory" class="text-[10px] uppercase tracking-[0.3em] font-medium border-b border-black pb-1 hover:pop-accent transition-colors">View All Auditory →</a>
      </div>
    </div>
  </section>

  <!-- Newsletter Footer CTA -->
  <section class="pt-32 pb-12 bg-white border-t wabi-border">
    <div class="container mx-auto px-6 md:px-12">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-16 mb-32">
        <div class="md:col-span-5">
          <h2 class="text-5xl font-bold tracking-[0.3em] mb-10">HANYA<span class="pop-accent">.</span></h2>
          <p class="text-gray-400 max-w-sm font-light text-lg leading-relaxed mb-12">A sensory journey through the layers of home. Fusing the raw soul of Bali with the electric spirit of modern art.</p>
          <div class="flex space-x-6">
            <div class="w-10 h-10 bg-black flex items-center justify-center hover:bg-pop transition-colors cursor-pointer"><span class="text-white text-xs">IG</span></div>
            <div class="w-10 h-10 bg-black flex items-center justify-center hover:bg-pop transition-colors cursor-pointer"><span class="text-white text-xs">TW</span></div>
            <div class="w-10 h-10 bg-black flex items-center justify-center hover:bg-pop transition-colors cursor-pointer"><span class="text-white text-xs">PI</span></div>
          </div>
        </div>
        <div class="md:col-span-2">
          <h4 class="text-[10px] uppercase tracking-[0.4em] font-bold mb-10">Shop Layers</h4>
          <ul class="space-y-6 text-[10px] uppercase tracking-[0.2em] font-medium text-gray-400">
            <li><a href="/visual" class="hover:text-black transition-colors">01. The Visual</a></li>
            <li><a href="/tactical" class="hover:text-black transition-colors">02. The Tactical</a></li>
            <li><a href="/auditory" class="hover:text-black transition-colors">03. The Auditory</a></li>
            <li><a href="#" class="hover:text-black transition-colors">New Arrivals</a></li>
          </ul>
        </div>
        <div class="md:col-span-2">
          <h4 class="text-[10px] uppercase tracking-[0.4em] font-bold mb-10">Studio</h4>
          <ul class="space-y-6 text-[10px] uppercase tracking-[0.2em] font-medium text-gray-400">
            <li><a href="#" class="hover:text-black transition-colors">Our Story</a></li>
            <li><a href="#" class="hover:text-black transition-colors">Wabi-Sabi Philosophy</a></li>
            <li><a href="#" class="hover:text-black transition-colors">Journal</a></li>
            <li><a href="#" class="hover:text-black transition-colors">Contact</a></li>
          </ul>
        </div>
        <div class="md:col-span-3">
          <h4 class="text-[10px] uppercase tracking-[0.4em] font-bold mb-10">Join the Vibration</h4>
          <p class="text-sm text-gray-400 font-light mb-8 leading-relaxed">Weekly curations of sound, space, and spirit.</p>
          <div class="relative">
            <input type="email" placeholder="EMAIL ADDRESS" class="w-full bg-transparent border-b py-4 text-[10px] tracking-[0.2em] focus:outline-none transition-colors" style="border-color:var(--wabi-border)" />
            <button class="absolute right-0 top-1/2 -translate-y-1/2 text-[10px] font-bold tracking-[0.2em] pop-accent">JOIN</button>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script is:inline>
    document.querySelectorAll('a[href^="#"]').forEach(a => {
      a.addEventListener('click', e => {
        e.preventDefault();
        const el = document.querySelector(a.getAttribute('href'));
        if (el) el.scrollIntoView({ behavior: 'smooth' });
      });
    });
  </script>
</BaseLayout>
