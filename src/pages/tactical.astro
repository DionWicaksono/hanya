---
// src/pages/tactical.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import { products } from '../data/products.js';

const furniture = products.filter(p => p.layer === 'tactical' && p.category === 'Japandi-Bali Fusion');
const plants = products.filter(p => p.layer === 'tactical' && p.category === 'Architectural Plants');
const icons = products.filter(p => p.layer === 'tactical' && p.category === 'Design Icons');
---
<BaseLayout title="TACTICAL | HANYA — Furniture & Decor" activeLayer="tactical">
  <header class="pt-48 pb-24 border-b wabi-border">
    <div class="container mx-auto px-6 md:px-12">
      <div class="max-w-4xl">
        <span class="text-[10px] uppercase tracking-[0.4em] mb-6 block text-gray-400">Layer 02 — The Tactical</span>
        <h1 class="text-7xl md:text-[9rem] font-light leading-[0.85] mb-12 tracking-tighter">
          Furniture <br>& <span class="italic serif">Decor.</span>
        </h1>
        <p class="text-xl font-light text-gray-500 max-w-2xl leading-relaxed">
          A curated selection of low-profile Japandi-Bali fusion, architectural specimen plants, and refurbished mid-century icons. The "bones" of the soulful interior.
        </p>
      </div>
    </div>
  </header>

  <!-- Japandi-Bali Fusion -->
  <section class="py-32 border-b wabi-border">
    <div class="container mx-auto px-6 md:px-12">
      <div class="flex flex-col md:flex-row justify-between items-end mb-24">
        <div>
          <h2 class="text-5xl md:text-7xl font-light italic serif mb-4">Japandi-Bali <span class="pop-accent">Fusion</span></h2>
          <p class="text-[10px] uppercase tracking-[0.3em] text-gray-400">Reclaimed Timber & Low Profiles</p>
        </div>
        <p class="text-sm text-gray-500 max-w-xs mt-8 md:mt-0 font-light">Heavy Balinese timber meeting classic Japanese height. Pieces designed to ground the space.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
        {furniture.map((p, i) => (
          <div class="product-reveal group" style={`transition-delay:${i*200}ms`}>
            <a href={`/products/${p.slug}`}>
              <div class="aspect-[4/3] bg-gray-100 overflow-hidden wabi-border mb-8 hover-zoom">
                <img src={p.image} alt={p.name} class="w-full h-full object-cover" />
              </div>
            </a>
            <div class="flex justify-between items-start">
              <div>
                <h3 class="text-3xl font-light mb-2">{p.name}</h3>
                <p class="text-sm text-gray-400 font-light mb-6">{p.description.substring(0,80)}…</p>
                <ul class="text-[10px] uppercase tracking-widest text-gray-500 space-y-2">
                  {p.details.map(d => <li>{d}</li>)}
                </ul>
              </div>
              <div class="text-right ml-8 flex-shrink-0">
                <p class="text-2xl font-light mb-4">${p.price.toLocaleString()}</p>
                <button class="px-8 py-3 bg-black text-white text-[10px] uppercase tracking-widest hover:bg-pop transition-colors add-to-cart"
                  data-id={p.id} data-name={p.name} data-price={p.price} data-image={p.image}>Add to Bag</button>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Architectural Plants -->
  <section class="py-32" style="background:#121212;color:#fdfdfb">
    <div class="container mx-auto px-6 md:px-12">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-20 items-center">
        <div class="lg:col-span-5">
          <span class="text-[10px] uppercase tracking-[0.4em] mb-6 block text-gray-600">Layer 02.B</span>
          <h2 class="text-6xl md:text-8xl font-light italic serif leading-tight mb-12">Architectural <br><span class="pop-accent">Plants.</span></h2>
          <p class="text-lg text-gray-400 font-light leading-relaxed mb-16">
            Selling only "specimen" plants—those with unusual, sculptural trunks that act as living art. Housed in matte-finish volcanic ceramic pots.
          </p>
          {plants.map(p => (
            <div class="product-reveal group">
              <h3 class="text-4xl font-light mb-4">{p.name}</h3>
              <p class="text-sm text-gray-500 font-light mb-8">{p.description.substring(0,100)}…</p>
              <div class="flex items-center space-x-8">
                <span class="text-3xl font-light">${p.price.toLocaleString()}</span>
                <button class="px-10 py-4 border border-white text-[10px] uppercase tracking-widest hover:bg-pop hover:border-pop transition-all add-to-cart"
                  data-id={p.id} data-name={p.name} data-price={p.price} data-image={p.image}>Enquire</button>
              </div>
            </div>
          ))}
        </div>
        <div class="lg:col-span-7">
          {plants.map(p => (
            <div class="relative aspect-[3/4] overflow-hidden wabi-border" style="background:#18181b">
              <img src={p.image} alt={p.name} class="w-full h-full object-cover opacity-80" />
              {p.badge && <div class="absolute bottom-12 right-12 bg-pop p-8 hidden md:block"><p class="text-[10px] uppercase tracking-[0.3em] font-bold text-white">{p.badge}</p></div>}
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Design Icons -->
  <section class="py-32 border-b wabi-border">
    <div class="container mx-auto px-6 md:px-12">
      <div class="flex flex-col items-center text-center mb-24">
        <h2 class="text-6xl md:text-9xl font-light italic serif leading-none mb-8">Design <span class="pop-accent">Icons.</span></h2>
        <p class="text-lg font-light text-gray-500 max-w-xl leading-relaxed">Curated, refurbished mid-century modern pieces that act as the structural "bones" for your interior.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-16">
        {icons.map((p, i) => (
          <div class="product-reveal group" style={`transition-delay:${i*200}ms`}>
            <a href={`/products/${p.slug}`}>
              <div class="aspect-square bg-gray-50 overflow-hidden wabi-border mb-8 hover-zoom">
                <img src={p.image} alt={p.name} class="w-full h-full object-cover" />
              </div>
              <h3 class="text-2xl font-light mb-2">{p.name}</h3>
              <p class="text-[10px] uppercase tracking-widest text-gray-400 mb-6">{p.category}</p>
            </a>
            <div class="flex justify-between items-center">
              <p class="text-xl font-medium">${p.price.toLocaleString()}</p>
              <button class="px-6 py-2 bg-black text-white text-[10px] uppercase tracking-widest hover:bg-pop transition-colors add-to-cart"
                data-id={p.id} data-name={p.name} data-price={p.price} data-image={p.image}>Add to Bag</button>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <script is:inline>
    document.querySelectorAll('.add-to-cart').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        const { id, name, price, image } = btn.dataset;
        const cart = JSON.parse(localStorage.getItem('hanya-cart') || '[]');
        const existing = cart.find(i => i.id === id);
        if (existing) existing.qty = (existing.qty || 1) + 1;
        else cart.push({ id, name, price: Number(price), image, qty: 1 });
        localStorage.setItem('hanya-cart', JSON.stringify(cart));
        window.dispatchEvent(new Event('cart-updated'));
        btn.textContent = '✓ Added';
        setTimeout(() => btn.textContent = 'Add to Bag', 1500);
      });
    });
  </script>
</BaseLayout>
