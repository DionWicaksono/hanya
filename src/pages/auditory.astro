---
// src/pages/auditory.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import { products } from '../data/products.js';

const vinyl = products.filter(p => p.layer === 'auditory' && p.category !== 'Sound Hardware');
const hardware = products.filter(p => p.layer === 'auditory' && p.category === 'Sound Hardware');
---
<BaseLayout title="AUDITORY | HANYA — Vinyl & Sound" activeLayer="auditory">
  <!-- Category Header -->
  <header class="pt-48 pb-24 border-b wabi-border">
    <div class="container mx-auto px-6 md:px-12">
      <div class="max-w-4xl">
        <span class="text-[10px] uppercase tracking-[0.4em] mb-6 block text-gray-400">Layer 03 — The Auditory</span>
        <h1 class="text-7xl md:text-[9rem] font-light leading-[0.85] mb-12 tracking-tighter">
          Vinyl & <br><span class="italic serif">Sound.</span>
        </h1>
        <div class="flex items-center space-x-4 mb-12">
          <div class="audio-wave w-24"></div>
          <p class="text-xl font-light text-gray-500 max-w-2xl leading-relaxed">
            A dedicated corner for high-fidelity sound. Curated Japanese City Pop, Indie-Tropical rhythms, and minimalist hardware that disappears into the interior.
          </p>
        </div>
      </div>
    </div>
  </header>

  <!-- Vinyl Section -->
  <section class="py-32 border-b wabi-border">
    <div class="container mx-auto px-6 md:px-12">
      <div class="flex flex-col md:flex-row justify-between items-end mb-24">
        <div>
          <h2 class="text-5xl md:text-7xl font-light italic serif mb-4">The <span class="pop-accent">Vinyl</span> Niche</h2>
          <p class="text-[10px] uppercase tracking-[0.3em] text-gray-400">Japanese City Pop & Lo-fi Beats</p>
        </div>
        <p class="text-sm text-gray-500 max-w-xs mt-8 md:mt-0 font-light">Rare pressings and limited editions curated for the soulful listener.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        {vinyl.map((p, i) => (
          <div class="product-reveal group cursor-pointer" style={`transition-delay:${i*100}ms`}>
            <a href={`/products/${p.slug}`}>
              <div class="aspect-square bg-gray-100 overflow-hidden wabi-border mb-6 relative hover-zoom">
                <img src={p.image} alt={p.name} class={`w-full h-full object-cover ${i % 2 !== 0 ? 'grayscale' : ''}`} />
                <div class="absolute inset-0 bg-pop mix-blend-overlay opacity-0 group-hover:opacity-40 transition-opacity"></div>
              </div>
              <h3 class="text-xl font-light mb-1">{p.name}</h3>
              <p class="text-[10px] uppercase tracking-widest text-gray-400 mb-4">{p.category}</p>
              <p class="text-lg font-medium">${p.price}</p>
            </a>
            <button class="mt-3 text-[10px] uppercase tracking-widest border-b border-black pb-1 hover:pop-accent transition-colors add-to-cart"
              data-id={p.id} data-name={p.name} data-price={p.price} data-image={p.image}>Add to Bag</button>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Hardware Section -->
  <section class="py-32" style="background:#121212;color:#fdfdfb">
    <div class="container mx-auto px-6 md:px-12">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-20 items-center">
        <div class="lg:col-span-7">
          <div class="relative aspect-video overflow-hidden wabi-border" style="background:#27272a">
            <img src="https://images.unsplash.com/photo-1461360370896-922624d12aa1?auto=format&fit=crop&q=80&w=1200" alt="Transparent Turntable" class="w-full h-full object-cover opacity-60 hover:opacity-100 transition-opacity duration-1000" />
            <div class="absolute inset-0 flex items-center justify-center">
              <div class="w-32 h-32 rounded-full flex items-center justify-center vinyl-spin" style="border:1px solid rgba(255,255,255,0.2)">
                <div class="w-2 h-2 bg-pop rounded-full"></div>
              </div>
            </div>
          </div>
        </div>
        <div class="lg:col-span-5">
          <span class="text-[10px] uppercase tracking-[0.4em] mb-6 block text-gray-600">The Hardware</span>
          <h2 class="text-6xl md:text-8xl font-light italic serif leading-tight mb-12">Transparent <br><span class="pop-accent">Sound.</span></h2>
          {hardware.map((p, i) => (
            <div class="product-reveal group mb-16" style={`transition-delay:${i*200}ms`}>
              <h3 class="text-4xl font-light mb-4">{p.name}</h3>
              <p class="text-sm text-gray-500 font-light mb-8 leading-relaxed">{p.description}</p>
              <div class="flex items-center space-x-8">
                <span class="text-3xl font-light">${p.price.toLocaleString()}</span>
                <button class="px-10 py-4 border border-white text-[10px] uppercase tracking-widest hover:bg-pop hover:border-pop transition-all add-to-cart"
                  data-id={p.id} data-name={p.name} data-price={p.price} data-image={p.image}>Add to Bag</button>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Vibe Section -->
  <section class="py-32 relative overflow-hidden">
    <div class="container mx-auto px-6 md:px-12 text-center">
      <h2 class="text-6xl md:text-9xl font-light italic serif leading-none mb-12">Listen to the <span class="pop-accent">Imperfection.</span></h2>
      <div class="max-w-3xl mx-auto">
        <div class="aspect-video bg-gray-100 wabi-border overflow-hidden relative group">
          <img src="https://images.unsplash.com/photo-1535992165812-68d1861aa71e?auto=format&fit=crop&q=80&w=1200" alt="Lo-fi Aesthetic" class="w-full h-full object-cover grayscale" />
          <div class="absolute inset-0 bg-pop opacity-20" style="mix-blend-mode:screen"></div>
          <div class="absolute inset-0 flex items-center justify-center">
            <button class="w-20 h-20 bg-white rounded-full flex items-center justify-center hover:scale-110 transition-transform">
              <svg class="w-8 h-8 text-black" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
            </button>
          </div>
        </div>
        <p class="mt-8 text-[10px] uppercase tracking-[0.5em] text-gray-400">Now Streaming: Hanya Lo-fi Radio</p>
      </div>
    </div>
  </section>

  <script is:inline>
    document.querySelectorAll('.add-to-cart').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        const { id, name, price, image } = btn.dataset;
        const cart = JSON.parse(localStorage.getItem('hanya-cart') || '[]');
        const existing = cart.find(i => i.id === id);
        if (existing) existing.qty = (existing.qty || 1) + 1;
        else cart.push({ id, name, price: Number(price), image, qty: 1 });
        localStorage.setItem('hanya-cart', JSON.stringify(cart));
        window.dispatchEvent(new Event('cart-updated'));
        btn.textContent = '✓ Added';
        setTimeout(() => btn.textContent = 'Add to Bag', 1500);
      });
    });
  </script>
</BaseLayout>
