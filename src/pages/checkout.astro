---
// src/pages/checkout.astro
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Checkout | HANYA">
  <div class="pt-40 pb-32">
    <div class="container mx-auto px-6 md:px-12">
      <div class="mb-16">
        <span class="text-[10px] uppercase tracking-[0.4em] mb-4 block text-gray-400">Secure Checkout</span>
        <h1 class="text-6xl md:text-8xl font-light italic serif">Complete <span class="pop-accent">Order.</span></h1>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-20">
        <!-- Form -->
        <div class="lg:col-span-7 space-y-16">
          <!-- Contact -->
          <div>
            <h2 class="text-[10px] uppercase tracking-[0.4em] font-bold mb-8">01 — Contact</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div class="col-span-2">
                <input type="email" placeholder="EMAIL ADDRESS" id="email" class="w-full bg-transparent border-b py-4 text-sm tracking-[0.1em] focus:outline-none transition-colors" style="border-color:var(--wabi-border)" />
              </div>
            </div>
          </div>

          <!-- Shipping -->
          <div>
            <h2 class="text-[10px] uppercase tracking-[0.4em] font-bold mb-8">02 — Shipping Address</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <input type="text" placeholder="FIRST NAME" id="fname" class="w-full bg-transparent border-b py-4 text-sm tracking-[0.1em] focus:outline-none" style="border-color:var(--wabi-border)" />
              <input type="text" placeholder="LAST NAME" id="lname" class="w-full bg-transparent border-b py-4 text-sm tracking-[0.1em] focus:outline-none" style="border-color:var(--wabi-border)" />
              <input type="text" placeholder="ADDRESS LINE 1" id="addr1" class="md:col-span-2 w-full bg-transparent border-b py-4 text-sm tracking-[0.1em] focus:outline-none" style="border-color:var(--wabi-border)" />
              <input type="text" placeholder="ADDRESS LINE 2 (OPTIONAL)" id="addr2" class="md:col-span-2 w-full bg-transparent border-b py-4 text-sm tracking-[0.1em] focus:outline-none" style="border-color:var(--wabi-border)" />
              <input type="text" placeholder="CITY" id="city" class="w-full bg-transparent border-b py-4 text-sm tracking-[0.1em] focus:outline-none" style="border-color:var(--wabi-border)" />
              <input type="text" placeholder="POSTAL CODE" id="postal" class="w-full bg-transparent border-b py-4 text-sm tracking-[0.1em] focus:outline-none" style="border-color:var(--wabi-border)" />
              <select id="country" class="md:col-span-2 w-full bg-transparent border-b py-4 text-sm tracking-[0.1em] focus:outline-none text-gray-500 appearance-none" style="border-color:var(--wabi-border)">
                <option value="">COUNTRY</option>
                <option value="ID">Indonesia</option>
                <option value="AU">Australia</option>
                <option value="SG">Singapore</option>
                <option value="JP">Japan</option>
                <option value="US">United States</option>
                <option value="GB">United Kingdom</option>
                <option value="NL">Netherlands</option>
                <option value="DE">Germany</option>
                <option value="FR">France</option>
              </select>
            </div>
          </div>

          <!-- Shipping Method -->
          <div>
            <h2 class="text-[10px] uppercase tracking-[0.4em] font-bold mb-8">03 — Shipping Method</h2>
            <div class="space-y-4">
              <label class="flex items-center justify-between p-6 border cursor-pointer hover:border-black transition-colors group" style="border-color:var(--wabi-border)" id="ship-standard-label">
                <div class="flex items-center gap-4">
                  <input type="radio" name="shipping" value="standard" checked class="accent-black" id="ship-standard" />
                  <div>
                    <p class="text-sm font-medium">Standard Shipping</p>
                    <p class="text-[10px] uppercase tracking-widest text-gray-400">7–14 business days</p>
                  </div>
                </div>
                <span class="text-sm font-medium" id="ship-standard-price">$25</span>
              </label>
              <label class="flex items-center justify-between p-6 border cursor-pointer hover:border-black transition-colors" style="border-color:var(--wabi-border)">
                <div class="flex items-center gap-4">
                  <input type="radio" name="shipping" value="express" class="accent-black" id="ship-express" />
                  <div>
                    <p class="text-sm font-medium">Express Shipping</p>
                    <p class="text-[10px] uppercase tracking-widest text-gray-400">3–5 business days</p>
                  </div>
                </div>
                <span class="text-sm font-medium">$65</span>
              </label>
              <label class="flex items-center justify-between p-6 border cursor-pointer hover:border-black transition-colors" style="border-color:var(--wabi-border)">
                <div class="flex items-center gap-4">
                  <input type="radio" name="shipping" value="local" class="accent-black" id="ship-local" />
                  <div>
                    <p class="text-sm font-medium">Local Bali Delivery</p>
                    <p class="text-[10px] uppercase tracking-widest text-gray-400">1–2 business days</p>
                  </div>
                </div>
                <span class="text-sm font-medium">$10</span>
              </label>
            </div>
          </div>

          <!-- Payment -->
          <div>
            <h2 class="text-[10px] uppercase tracking-[0.4em] font-bold mb-8">04 — Payment</h2>
            <div class="p-6 border wabi-border mb-6 bg-gray-50">
              <p class="text-[10px] uppercase tracking-widest text-gray-400 mb-2">Card Number</p>
              <input type="text" placeholder="4242 4242 4242 4242" maxlength="19" id="card-num" class="w-full bg-transparent text-sm tracking-[0.15em] focus:outline-none" oninput="formatCard(this)" />
            </div>
            <div class="grid grid-cols-2 gap-6">
              <div class="p-6 border wabi-border bg-gray-50">
                <p class="text-[10px] uppercase tracking-widest text-gray-400 mb-2">Expiry</p>
                <input type="text" placeholder="MM / YY" maxlength="7" id="card-exp" class="w-full bg-transparent text-sm tracking-[0.15em] focus:outline-none" oninput="formatExpiry(this)" />
              </div>
              <div class="p-6 border wabi-border bg-gray-50">
                <p class="text-[10px] uppercase tracking-widest text-gray-400 mb-2">CVC</p>
                <input type="text" placeholder="•••" maxlength="4" id="card-cvc" class="w-full bg-transparent text-sm tracking-[0.15em] focus:outline-none" />
              </div>
            </div>
          </div>
        </div>

        <!-- Order Summary Sidebar -->
        <div class="lg:col-span-5">
          <div class="sticky top-32 border wabi-border p-10">
            <h3 class="text-[10px] uppercase tracking-[0.4em] font-bold mb-8">Order Summary</h3>
            <div id="checkout-items" class="space-y-6 mb-8 border-b pb-8" style="border-color:var(--wabi-border)"></div>
            <div class="space-y-4 mb-8 border-b pb-8" style="border-color:var(--wabi-border)">
              <div class="flex justify-between text-sm text-gray-500">
                <span>Subtotal</span><span id="co-subtotal">$0</span>
              </div>
              <div class="flex justify-between text-sm text-gray-500">
                <span>Shipping</span><span id="co-shipping">$25</span>
              </div>
              <div class="flex justify-between text-sm text-gray-500">
                <span>Tax (11% PPN)</span><span id="co-tax">$0</span>
              </div>
            </div>
            <div class="flex justify-between font-medium mb-10">
              <span>Total</span><span id="co-total" class="text-2xl">$0</span>
            </div>

            <button id="place-order-btn" onclick="placeOrder()" class="w-full py-5 bg-black text-white text-[10px] uppercase tracking-[0.3em] hover:bg-pop transition-colors">
              Place Order
            </button>
            <p class="text-[10px] text-gray-400 text-center mt-4 tracking-widest">SSL ENCRYPTED · SECURE PAYMENT</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Success Modal -->
  <div id="success-modal" class="fixed inset-0 z-50 hidden items-center justify-center" style="background:rgba(0,0,0,0.8)">
    <div class="bg-white max-w-lg w-full mx-6 p-16 text-center">
      <div class="w-16 h-16 bg-pop rounded-full flex items-center justify-center mx-auto mb-8">
        <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
      </div>
      <h2 class="text-4xl font-light italic serif mb-4">Order <span class="pop-accent">Placed.</span></h2>
      <p class="text-gray-500 font-light mb-4">Thank you for your order. A confirmation will be sent to your email.</p>
      <p id="order-number" class="text-[10px] uppercase tracking-[0.4em] text-gray-400 mb-12"></p>
      <a href="/" onclick="clearCart()" class="inline-block px-12 py-4 bg-black text-white text-[10px] uppercase tracking-[0.3em] hover:bg-pop transition-colors">Back to Home</a>
    </div>
  </div>

  <script is:inline>
    const shippingCosts = { standard: 25, express: 65, local: 10 };
    let selectedShipping = 'standard';

    function formatPrice(n) { return '$' + n.toLocaleString('en-US', { minimumFractionDigits: 0 }); }
    function formatCard(el) {
      let v = el.value.replace(/\D/g,'').substring(0,16);
      el.value = v.replace(/(.{4})/g,'$1 ').trim();
    }
    function formatExpiry(el) {
      let v = el.value.replace(/\D/g,'');
      if (v.length >= 2) v = v.substring(0,2) + ' / ' + v.substring(2,4);
      el.value = v;
    }

    function renderCheckout() {
      const cart = JSON.parse(localStorage.getItem('hanya-cart') || '[]');
      const ship = shippingCosts[selectedShipping];
      const subtotal = cart.reduce((s, i) => s + i.price * (i.qty || 1), 0);
      const tax = Math.round(subtotal * 0.11);
      const total = subtotal + ship + tax;

      document.getElementById('checkout-items').innerHTML = cart.map(item => `
        <div class="flex gap-4 items-center">
          <img src="${item.image}" alt="${item.name}" class="w-16 h-20 object-cover flex-shrink-0" style="border:1px solid var(--wabi-border)"/>
          <div class="flex-1">
            <p class="text-sm font-light leading-snug">${item.name}</p>
            <p class="text-[10px] uppercase tracking-widest text-gray-400 mt-1">Qty: ${item.qty || 1}</p>
          </div>
          <span class="text-sm font-medium">${formatPrice(item.price * (item.qty || 1))}</span>
        </div>
      `).join('') || '<p class="text-sm text-gray-400">No items in bag.</p>';

      document.getElementById('co-subtotal').textContent = formatPrice(subtotal);
      document.getElementById('co-shipping').textContent = formatPrice(ship);
      document.getElementById('co-tax').textContent = formatPrice(tax);
      document.getElementById('co-total').textContent = formatPrice(total);
    }

    document.querySelectorAll('input[name="shipping"]').forEach(radio => {
      radio.addEventListener('change', () => { selectedShipping = radio.value; renderCheckout(); });
    });

    function placeOrder() {
      const email = document.getElementById('email').value;
      const fname = document.getElementById('fname').value;
      const cardNum = document.getElementById('card-num').value;
      if (!email || !fname || cardNum.replace(/\s/g,'').length < 16) {
        alert('Please fill in all required fields.');
        return;
      }
      const orderNum = 'HNYA-' + Math.random().toString(36).substring(2,8).toUpperCase();
      document.getElementById('order-number').textContent = 'Order #' + orderNum;
      document.getElementById('success-modal').classList.remove('hidden');
      document.getElementById('success-modal').classList.add('flex');
    }

    function clearCart() {
      localStorage.removeItem('hanya-cart');
      window.dispatchEvent(new Event('cart-updated'));
    }

    renderCheckout();
  </script>
</BaseLayout>
