---
// src/pages/products/[slug].astro
import BaseLayout from '../../layouts/BaseLayout.astro';
import { products, getProductBySlug } from '../../data/products.js';

export function getStaticPaths() {
  return products.map(p => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const product = getProductBySlug(slug);

// Related products (same layer, different product)
const related = products.filter(p => p.layer === product.layer && p.id !== product.id).slice(0, 3);

const layerUrl = `/${product.layer}`;
const layerName = product.layerLabel;
---
<BaseLayout title={`${product.name} | HANYA`} activeLayer={product.layer}>
  <!-- Breadcrumb -->
  <div class="pt-36 pb-8 border-b wabi-border">
    <div class="container mx-auto px-6 md:px-12">
      <div class="flex items-center space-x-3 text-[10px] uppercase tracking-[0.3em] text-gray-400">
        <a href="/" class="hover:text-black transition-colors">Home</a>
        <span>/</span>
        <a href={layerUrl} class="hover:text-black transition-colors">{product.layer.charAt(0).toUpperCase() + product.layer.slice(1)}</a>
        <span>/</span>
        <span class="text-black">{product.name}</span>
      </div>
    </div>
  </div>

  <!-- Product Detail -->
  <section class="py-20">
    <div class="container mx-auto px-6 md:px-12">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-20 items-start">
        <!-- Image -->
        <div class="lg:col-span-7">
          <div class="aspect-[4/5] bg-gray-100 overflow-hidden wabi-border relative group">
            <img src={product.image} alt={product.name} class="w-full h-full object-cover hover:scale-105 transition-transform duration-700" />
            {product.badge && (
              <div class={`absolute top-8 left-8 px-4 py-2 text-[10px] uppercase tracking-widest font-bold ${product.badgeStyle === 'pop' ? 'bg-pop text-white' : product.badgeStyle === 'dark' ? 'bg-black text-white' : 'bg-white text-black'}`}>
                {product.badge}
              </div>
            )}
          </div>
        </div>

        <!-- Info -->
        <div class="lg:col-span-5 lg:sticky lg:top-32">
          <span class="text-[10px] uppercase tracking-[0.4em] mb-4 block text-gray-400">{layerName}</span>
          <span class="text-[10px] uppercase tracking-[0.3em] mb-6 block pop-accent">{product.category}</span>
          
          <h1 class="text-5xl md:text-6xl font-light mb-8 leading-tight">{product.name}</h1>
          
          <p class="text-3xl font-light mb-10">${product.price.toLocaleString()}</p>
          
          <p class="text-base text-gray-600 font-light leading-relaxed mb-12">{product.description}</p>
          
          <!-- Product Details -->
          <div class="mb-12 border-t border-b py-8" style="border-color:var(--wabi-border)">
            <h4 class="text-[10px] uppercase tracking-[0.4em] font-bold mb-6">Product Details</h4>
            <ul class="space-y-3">
              {product.details.map(d => (
                <li class="text-sm text-gray-500 flex items-start gap-3">
                  <span class="w-1 h-1 rounded-full bg-pop mt-2 flex-shrink-0"></span>
                  {d}
                </li>
              ))}
            </ul>
          </div>
          
          <!-- Quantity + Add to Cart -->
          <div class="flex items-center gap-4 mb-6">
            <div class="flex items-center border wabi-border">
              <button id="qty-minus" class="w-12 h-12 flex items-center justify-center hover:bg-gray-100 transition-colors text-xl">−</button>
              <span id="qty-display" class="w-12 h-12 flex items-center justify-center text-sm font-medium">1</span>
              <button id="qty-plus" class="w-12 h-12 flex items-center justify-center hover:bg-gray-100 transition-colors text-xl">+</button>
            </div>
            <button id="add-to-cart-btn" class="flex-1 py-4 bg-black text-white text-[10px] uppercase tracking-[0.3em] hover:bg-pop transition-colors"
              data-id={product.id} data-name={product.name} data-price={product.price} data-image={product.image}>
              Add to Bag
            </button>
          </div>

          <a href="/cart" class="block w-full py-4 border wabi-border text-[10px] uppercase tracking-[0.3em] text-center hover:border-black transition-colors">
            View Bag
          </a>

          <!-- Layer badge -->
          <div class="mt-12 p-6" style="background:#f5f5f3">
            <p class="text-[10px] uppercase tracking-[0.3em] text-gray-400 mb-2">{layerName}</p>
            <a href={layerUrl} class="text-sm font-light hover:pop-accent transition-colors">Browse more from this layer →</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Related Products -->
  {related.length > 0 && (
    <section class="py-24 border-t wabi-border">
      <div class="container mx-auto px-6 md:px-12">
        <h2 class="text-4xl font-light italic serif mb-16">You may also <span class="pop-accent">want.</span></h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
          {related.map((p, i) => (
            <div class="product-reveal group" style={`transition-delay:${i*150}ms`}>
              <a href={`/products/${p.slug}`}>
                <div class="aspect-[3/4] bg-gray-100 overflow-hidden wabi-border mb-6 hover-zoom">
                  <img src={p.image} alt={p.name} class="w-full h-full object-cover" />
                </div>
                <h3 class="text-xl font-light mb-1">{p.name}</h3>
                <p class="text-[10px] uppercase tracking-widest text-gray-400 mb-3">{p.category}</p>
                <p class="text-lg font-medium">${p.price.toLocaleString()}</p>
              </a>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <script is:inline>
    let qty = 1;
    const qtyDisplay = document.getElementById('qty-display');
    document.getElementById('qty-minus').addEventListener('click', () => {
      if (qty > 1) { qty--; qtyDisplay.textContent = qty; }
    });
    document.getElementById('qty-plus').addEventListener('click', () => {
      qty++; qtyDisplay.textContent = qty;
    });

    document.getElementById('add-to-cart-btn').addEventListener('click', () => {
      const btn = document.getElementById('add-to-cart-btn');
      const { id, name, price, image } = btn.dataset;
      const cart = JSON.parse(localStorage.getItem('hanya-cart') || '[]');
      const existing = cart.find(i => i.id === id);
      if (existing) existing.qty = (existing.qty || 1) + qty;
      else cart.push({ id, name, price: Number(price), image, qty });
      localStorage.setItem('hanya-cart', JSON.stringify(cart));
      window.dispatchEvent(new Event('cart-updated'));
      btn.textContent = `✓ ${qty > 1 ? qty + 'x ' : ''}Added to Bag`;
      setTimeout(() => btn.textContent = 'Add to Bag', 2000);
    });
  </script>
</BaseLayout>
