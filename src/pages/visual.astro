---
// src/pages/visual.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import { products } from '../data/products.js';

const statues = products.filter(p => p.layer === 'visual' && p.category !== 'Giclée Print');
const prints = products.filter(p => p.layer === 'visual' && p.category === 'Giclée Print');
---
<BaseLayout title="VISUAL | HANYA — Art & Statues" activeLayer="visual">
  <!-- Category Header -->
  <header class="pt-48 pb-24 border-b wabi-border relative overflow-hidden">
    <div class="absolute inset-0 halftone-bg"></div>
    <div class="container mx-auto px-6 md:px-12 relative z-10">
      <div class="max-w-4xl">
        <span class="text-[10px] uppercase tracking-[0.4em] mb-6 block text-gray-400">Layer 01 — The Visual</span>
        <h1 class="text-7xl md:text-[9rem] font-light leading-[0.85] mb-12 tracking-tighter">
          Art & <br><span class="italic serif">Statues.</span>
        </h1>
        <p class="text-xl font-light text-gray-500 max-w-2xl leading-relaxed">
          A dialogue between the organic silence of Balinese suar wood and the electric vibrance of industrial resin. Where traditional silhouettes meet 90s grunge aesthetics.
        </p>
      </div>
    </div>
  </header>

  <!-- Statues Section -->
  <section class="py-32 border-t wabi-border">
    <div class="container mx-auto px-6 md:px-12">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-20 items-start">
        <!-- Natural Column -->
        <div class="lg:col-span-6 space-y-24">
          <div class="flex items-center space-x-4 mb-12">
            <span class="text-[10px] uppercase tracking-[0.4em] font-bold">Natural</span>
            <div class="h-[1px] flex-grow bg-gray-200"></div>
          </div>
          {statues.filter(p => p.badgeStyle !== 'pop').map((p, i) => (
            <div class="product-reveal group" style={`transition-delay:${i*100}ms`}>
              <a href={`/products/${p.slug}`}>
                <div class="aspect-[3/4] bg-gray-100 overflow-hidden wabi-border mb-8 hover-zoom">
                  <img src={p.image} alt={p.name} class="w-full h-full object-cover" style="filter:grayscale(0.2)" />
                </div>
                <h3 class="text-4xl font-light mb-4">{p.name}</h3>
                <p class="text-sm text-gray-500 font-light mb-8 leading-relaxed">{p.description}</p>
                <div class="flex justify-between items-center border-t pt-6" style="border-color:var(--wabi-border)">
                  <span class="text-2xl font-light">${p.price.toLocaleString()}</span>
                  <button class="px-8 py-3 bg-black text-white text-[10px] uppercase tracking-widest hover:bg-pop transition-colors add-to-cart"
                    data-id={p.id} data-name={p.name} data-price={p.price} data-image={p.image}>Add to Bag</button>
                </div>
              </a>
            </div>
          ))}
        </div>
        <!-- Industrial Column -->
        <div class="lg:col-span-6 space-y-24 mt-24 lg:mt-48">
          <div class="flex items-center space-x-4 mb-12">
            <div class="h-[1px] flex-grow bg-gray-200"></div>
            <span class="text-[10px] uppercase tracking-[0.4em] font-bold pop-accent">Industrial</span>
          </div>
          {statues.filter(p => p.badgeStyle === 'pop').map((p, i) => (
            <div class="product-reveal group" style={`transition-delay:${i*100+200}ms`}>
              <a href={`/products/${p.slug}`}>
                <div class="aspect-[3/4] bg-gray-100 overflow-hidden wabi-border mb-8 hover-zoom relative">
                  <img src={p.image} alt={p.name} class="w-full h-full object-cover" />
                  <div class="absolute inset-0 bg-pop opacity-30 group-hover:opacity-60 transition-opacity" style="mix-blend-mode:color"></div>
                </div>
                <h3 class="text-4xl font-light mb-4">{p.name}</h3>
                <p class="text-sm text-gray-500 font-light mb-8 leading-relaxed">{p.description}</p>
                <div class="flex justify-between items-center border-t pt-6" style="border-color:var(--wabi-border)">
                  <span class="text-2xl font-light">${p.price.toLocaleString()}</span>
                  <button class="px-8 py-3 bg-black text-white text-[10px] uppercase tracking-widest hover:bg-pop transition-colors add-to-cart"
                    data-id={p.id} data-name={p.name} data-price={p.price} data-image={p.image}>Add to Bag</button>
                </div>
              </a>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Print Shop -->
  <section class="py-32 relative overflow-hidden" style="background:#121212;color:#fdfdfb">
    <div class="absolute inset-0 halftone-bg" style="opacity:0.1"></div>
    <div class="container mx-auto px-6 md:px-12 relative z-10">
      <div class="flex flex-col items-center text-center mb-24">
        <span class="text-[10px] uppercase tracking-[0.4em] mb-6 block text-gray-600">The Print Shop</span>
        <h2 class="text-6xl md:text-[8rem] font-light italic serif leading-none mb-8">Modern <span class="pop-accent">Ukiyo-e.</span></h2>
        <p class="text-lg text-gray-400 font-light max-w-xl leading-relaxed">
          Limited edition Giclée prints using halftone dots and layered textures. Traditional scenes re-imagined with 1990s grunge aesthetics.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-16">
        {prints.map((p, i) => (
          <div class="product-reveal group" style={`transition-delay:${i*200}ms`}>
            <a href={`/products/${p.slug}`}>
              <div class="aspect-[2/3] bg-zinc-900 overflow-hidden wabi-border mb-8 hover-zoom relative">
                <img src={p.image} alt={p.name} class="w-full h-full object-cover opacity-80 group-hover:opacity-100 transition-opacity" />
                {p.badge && <div class={`absolute top-8 left-8 px-4 py-2 text-[10px] uppercase tracking-widest font-bold ${p.badgeStyle === 'pop' ? 'bg-pop text-white' : 'bg-white text-black'}`}>{p.badge}</div>}
              </div>
              <div class="flex justify-between items-start">
                <div>
                  <h3 class="text-3xl font-light mb-2">{p.name}</h3>
                  <p class="text-sm text-gray-500 font-light">{p.details[0]}</p>
                </div>
                <span class="text-2xl font-light">${p.price.toLocaleString()}</span>
              </div>
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <script is:inline>
    document.querySelectorAll('.add-to-cart').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        const { id, name, price, image } = btn.dataset;
        const cart = JSON.parse(localStorage.getItem('hanya-cart') || '[]');
        const existing = cart.find(i => i.id === id);
        if (existing) existing.qty = (existing.qty || 1) + 1;
        else cart.push({ id, name, price: Number(price), image, qty: 1 });
        localStorage.setItem('hanya-cart', JSON.stringify(cart));
        window.dispatchEvent(new Event('cart-updated'));
        btn.textContent = '✓ Added';
        setTimeout(() => btn.textContent = 'Add to Bag', 1500);
      });
    });
  </script>
</BaseLayout>
