---
// src/pages/cart.astro
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Your Bag | HANYA">
  <div class="pt-40 pb-32">
    <div class="container mx-auto px-6 md:px-12">
      
      <div class="mb-16">
        <span class="text-[10px] uppercase tracking-[0.4em] mb-4 block text-gray-400">Your Bag</span>
        <h1 class="text-6xl md:text-8xl font-light italic serif">The <span class="pop-accent">Bag.</span></h1>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-20">
        <!-- Cart Items -->
        <div class="lg:col-span-7" id="cart-items">
          <!-- Rendered by JS -->
        </div>

        <!-- Order Summary -->
        <div class="lg:col-span-5">
          <div class="sticky top-32">
            <div class="p-10 border wabi-border">
              <h3 class="text-[10px] uppercase tracking-[0.4em] font-bold mb-10">Order Summary</h3>
              
              <div class="space-y-4 mb-8 border-b pb-8" style="border-color:var(--wabi-border)">
                <div class="flex justify-between text-sm text-gray-500">
                  <span>Subtotal</span>
                  <span id="summary-subtotal">$0</span>
                </div>
                <div class="flex justify-between text-sm text-gray-500">
                  <span>Shipping</span>
                  <span id="summary-shipping">Calculated at checkout</span>
                </div>
                <div class="flex justify-between text-sm text-gray-500">
                  <span>Tax (11% PPN)</span>
                  <span id="summary-tax">$0</span>
                </div>
              </div>

              <div class="flex justify-between font-medium mb-10">
                <span>Total</span>
                <span id="summary-total" class="text-2xl">$0</span>
              </div>

              <a href="/checkout" id="checkout-btn" class="block w-full py-5 bg-black text-white text-[10px] uppercase tracking-[0.3em] text-center hover:bg-pop transition-colors mb-4">
                Proceed to Checkout
              </a>
              <a href="/" class="block w-full py-5 border wabi-border text-[10px] uppercase tracking-[0.3em] text-center hover:border-black transition-colors">
                Continue Shopping
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- Empty State -->
      <div id="empty-cart" class="hidden py-32 text-center">
        <h2 class="text-5xl font-light italic serif mb-8">Your bag is <span class="pop-accent">empty.</span></h2>
        <p class="text-gray-500 font-light mb-12">Start exploring the layers of HANYA.</p>
        <a href="/" class="inline-block px-12 py-5 bg-black text-white text-[10px] uppercase tracking-[0.3em] hover:bg-pop transition-colors">Explore Now</a>
      </div>
    </div>
  </div>

  <script is:inline>
    function formatPrice(n) { return '$' + n.toLocaleString('en-US', { minimumFractionDigits: 0 }); }

    function renderCart() {
      const cart = JSON.parse(localStorage.getItem('hanya-cart') || '[]');
      const cartItemsEl = document.getElementById('cart-items');
      const emptyEl = document.getElementById('empty-cart');
      
      if (cart.length === 0) {
        cartItemsEl.innerHTML = '';
        emptyEl.classList.remove('hidden');
        updateSummary(0);
        return;
      }

      emptyEl.classList.add('hidden');
      cartItemsEl.innerHTML = cart.map((item, idx) => `
        <div class="flex gap-6 py-10 border-b" style="border-color:var(--wabi-border)">
          <a href="/products/${item.id}" class="w-32 h-40 flex-shrink-0 overflow-hidden" style="border:1px solid var(--wabi-border)">
            <img src="${item.image}" alt="${item.name}" class="w-full h-full object-cover" />
          </a>
          <div class="flex-1 flex flex-col justify-between">
            <div>
              <h3 class="text-xl font-light mb-2">${item.name}</h3>
              <p class="text-sm text-gray-400 font-light">${formatPrice(item.price)} each</p>
            </div>
            <div class="flex items-center justify-between">
              <div class="flex items-center" style="border:1px solid var(--wabi-border)">
                <button onclick="updateQty(${idx}, -1)" class="w-10 h-10 flex items-center justify-center hover:bg-gray-100 transition-colors">−</button>
                <span class="w-10 h-10 flex items-center justify-center text-sm">${item.qty || 1}</span>
                <button onclick="updateQty(${idx}, 1)" class="w-10 h-10 flex items-center justify-center hover:bg-gray-100 transition-colors">+</button>
              </div>
              <div class="flex items-center gap-8">
                <span class="text-lg font-medium">${formatPrice(item.price * (item.qty || 1))}</span>
                <button onclick="removeItem(${idx})" class="text-[10px] uppercase tracking-widest text-gray-400 hover:text-black transition-colors border-b" style="border-color:var(--wabi-border)">Remove</button>
              </div>
            </div>
          </div>
        </div>
      `).join('');

      const subtotal = cart.reduce((s, i) => s + i.price * (i.qty || 1), 0);
      updateSummary(subtotal);
    }

    function updateSummary(subtotal) {
      const tax = Math.round(subtotal * 0.11);
      const total = subtotal + tax;
      document.getElementById('summary-subtotal').textContent = formatPrice(subtotal);
      document.getElementById('summary-tax').textContent = formatPrice(tax);
      document.getElementById('summary-total').textContent = formatPrice(total);
    }

    function updateQty(idx, delta) {
      const cart = JSON.parse(localStorage.getItem('hanya-cart') || '[]');
      cart[idx].qty = Math.max(1, (cart[idx].qty || 1) + delta);
      localStorage.setItem('hanya-cart', JSON.stringify(cart));
      window.dispatchEvent(new Event('cart-updated'));
      renderCart();
    }

    function removeItem(idx) {
      const cart = JSON.parse(localStorage.getItem('hanya-cart') || '[]');
      cart.splice(idx, 1);
      localStorage.setItem('hanya-cart', JSON.stringify(cart));
      window.dispatchEvent(new Event('cart-updated'));
      renderCart();
    }

    renderCart();
    window.addEventListener('cart-updated', renderCart);
  </script>
</BaseLayout>
